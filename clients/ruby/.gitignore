# Rust build output (workspace target dir is at the gem root)
/target/

# compiled native extension (built into lib/ by `rake compile`)
/lib/unison_client/
*.bundle
*.so
*.o

# bundler
/Gemfile.lock
/.bundle/
/tmp/

# Cargo.lock は追跡する（native gem = cdylib の再現ビルドのため）。
# 親リポジトリの .gitignore が Cargo.lock を一律 ignore しているのを打ち消す。
!Cargo.lock
